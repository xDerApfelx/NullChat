{
    "name": "nullchat",
    "version": "3.1.0",
    "description": "Minimalistic P2P Chat & Voice App using Electron and PeerJS",
    "author": {
        "name": "xDerApfelx",
        "email": "117024724+xDerApfelx@users.noreply.github.com"
    },
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "debug1": "electron . --debug-instance=1",
        "debug2": "electron . --debug-instance=2",
        "debug3": "electron . --debug-instance=3",
        "make": "electron-builder --win --x64",
        "make:win": "electron-builder --win --x64",
        "make:mac": "electron-builder --mac --x64 --arm64",
        "make:linux": "electron-builder --linux --x64",
        "make:all": "electron-builder --win --x64 --mac --x64 --arm64 --linux --x64"
    },
    "dependencies": {
        "better-sqlite3": "^12.8.0",
        "peerjs": "^1.5.5",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "electron": "^41.0.3",
        "electron-builder": "^26.8.1"
    },
    "build": {
        "appId": "com.nullchat.app",
        "productName": "NullChat",
        "win": {
            "target": "nsis",
            "icon": "assets/icon.ico"
        },
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "icon": "assets/icon.icns",
            "category": "public.app-category.social-networking",
            "artifactName": "${productName}-${version}-mac.${ext}"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "icon": "assets/icon.png",
            "category": "Network;Chat;InstantMessaging",
            "artifactName": "${productName}-${version}-linux.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowElevation": false,
            "allowToChangeInstallationDirectory": true,
            "runAfterFinish": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "uninstallDisplayName": "NullChat Messenger",
            "artifactName": "${productName}-Setup-${version}.${ext}"
        },
        "files": [
            "main.js",
            "preload.js",
            "index.html",
            "renderer.js",
            "styles.css",
            "logger.js",
            "chatStore.js",
            "package.json",
            "assets"
        ]
    }
}